[Unit]
Description=Dropbox Client
After=remote-fs.target network.target seaf-cli.service

[Service]
User=syncadmin
Group=crandell
Type=simple
ExecStart=/home/syncadmin/.dropbox-dist/dropboxd
ExecStop=/usr/bin/killall -w -s 2 /home/syncadmin/.dropbox-dist/dropboxd
Restart=on-failure
RestartSec=1
#WorkingDirectory=/mnt/libraries
StandardOutput=file:///var/log/dropbox/dropbox.log
StandardError=file:///var/log/dropbox/dropbox.log

[Install]
WantedBy=multi-user.target
